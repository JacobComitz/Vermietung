<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="de.arvato.vermietung.controller.CartController"
            prefHeight="600.0" prefWidth="861.0"
            stylesheets="@style/userproductscreen.css"
            xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1">

    <center>
        <StackPane>

            <ImageView fitHeight="600.0" fitWidth="861.0" preserveRatio="false">
                <Image url="@img/VermietungBackground.jpg"/>
            </ImageView>

            <VBox spacing="20"
                  style="-fx-background-color: rgba(255,255,255,0.85);
                         -fx-background-radius: 12;">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <HBox alignment="CENTER_LEFT">
                    <Label text="🛒 Warenkorb"
                           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                </HBox>

                <ListView fx:id="cartListView"
                          prefHeight="350"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Gesamt:"
                           style="-fx-font-size: 16px;"/>
                    <Label fx:id="totalPriceLabel"
                           text="0,00 €"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="Zurück"
                            prefWidth="120"
                            styleClass="button-primary"
                            onAction="#closeCart"/>

                    <Button text="Mieten"
                            prefWidth="120"
                            styleClass="button-primary"
                            onAction="#checkout"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
